{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wanderstamp",
  "version": "1.0.0",
  "identifier": "app.wanderstamp",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wanderstamp",
        "label": "main",
        "url": "https://wanderstamp.example.com",
        "width": 420,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    }
  }
}
